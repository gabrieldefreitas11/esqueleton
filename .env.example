# ─── Core ───────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
DATABASE_URL=mysql://root:root@localhost:3306/saas_skeleton
JWT_SECRET=troque-isto-em-producao-com-uma-string-aleatoria-longa
COOKIE_DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost:3000

# Opcional: se definido, este openId/email será promovido a admin no primeiro
# login.
OWNER_OPEN_ID=

# Opcional: protege o endpoint /api/cron/abandoned-carts
CRON_SECRET=

# ─── Google OAuth ──────────────────────────────────────────────────────────
# Crie credenciais em https://console.cloud.google.com/apis/credentials
# Redirect URI autorizada: ${APP_URL}/api/auth/google/callback
# Também configurável via /admin/settings (site_settings tem prioridade).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── reCAPTCHA v3 (opcional — protege /login e /register) ─────────────────
# https://www.google.com/recaptcha/admin — v3 + seu domínio.
# Também configurável via /admin/settings. Deixe vazio pra desabilitar.
RECAPTCHA_SECRET_KEY=

# ─── MercadoPago ───────────────────────────────────────────────────────────
# Access token de produção/sandbox. Também pode ser configurado via admin UI
# (stored em siteSettings).
MP_ACCESS_TOKEN=

# ─── XGate (opcional — crypto/PIX) ─────────────────────────────────────────
# Também configurável via admin UI.
XGATE_EMAIL=
XGATE_PASSWORD=
XGATE_API_BASE_URL=

# ─── Mailjet (opcional — emails transacionais) ─────────────────────────────
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME=

# ─── LLM (opcional — multi-provider automático) ────────────────────────────
# Detecta o provider pelo prefixo da chave:
#   sk-ant-...  → Anthropic Claude (claude-haiku-4-5)
#   sk-...      → OpenAI (gpt-4o-mini)
#   outro       → Google Gemini (gemini-2.0-flash)
LLM_API_KEY=

# ─── Google Ads conversão (opcional) ───────────────────────────────────────
VITE_GOOGLE_ADS_BEGIN_CHECKOUT_SEND_TO=
VITE_GOOGLE_ADS_PURCHASE_SEND_TO=
